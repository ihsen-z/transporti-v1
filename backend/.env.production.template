# ============================================================================
# Transporti V1 — PRODUCTION Environment Variables Template
# ============================================================================
# INSTRUCTIONS: Copy this file to .env and fill in ALL values before deploying.
# NEVER commit the filled .env file to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# SECURITY (MANDATORY — App will crash without these)
# ---------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_50_CHAR_STRING

DEBUG=False
ENV=production
ALLOWED_HOSTS=transporti.tn,www.transporti.tn,api.transporti.tn

# ---------------------------------------------------------------------------
# DATABASE (PostgreSQL — MANDATORY)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://transporti_user:STRONG_PASSWORD_HERE@db-host:5432/transporti_prod

# ---------------------------------------------------------------------------
# CORS (frontend domain)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://transporti.tn,https://www.transporti.tn

# ---------------------------------------------------------------------------
# PAYMENT GATEWAY — Konnect.tn (MANDATORY for Go-Live)
# ---------------------------------------------------------------------------
# Register at https://konnect.network and get your production API key
PAYMENT_GATEWAY=KONNECT
KONNECT_API_KEY=YOUR_KONNECT_PRODUCTION_API_KEY
KONNECT_WALLET_ID=YOUR_KONNECT_WALLET_ID
KONNECT_API_URL=https://api.konnect.network/api/v2
COD_MAX_AMOUNT=300

# Webhook security — set a strong random string
PAYMENT_WEBHOOK_SECRET=GENERATE_A_RANDOM_32_CHAR_STRING

# ---------------------------------------------------------------------------
# EMAIL — SendGrid (MANDATORY for transactional emails)
# ---------------------------------------------------------------------------
# Register at https://sendgrid.com — Free tier: 100 emails/day
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
DEFAULT_FROM_EMAIL=noreply@transporti.tn

# Frontend URL for email links (password reset, etc.)
FRONTEND_URL=https://transporti.tn

# ---------------------------------------------------------------------------
# OPTIONAL — Monitoring & Performance
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn@o123.ingest.sentry.io/456
# REDIS_URL=redis://redis-host:6379/0
