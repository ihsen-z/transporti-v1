# Transporti V1 Environment Configuration
# Copy this file to .env and customize for your environment
# NEVER commit .env with real secrets to version control

# =============================================================================
# SECURITY
# =============================================================================

# Django Secret Key (generate a new one for production!)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-replace-in-production

# JWT Signing Key (separate from Django secret for security)
JWT_SECRET_KEY=jwt-insecure-dev-only-replace-in-production

# Debug Mode (set to False in production!)
DEBUG=True

# Allowed Hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE (for future PostgreSQL)
# =============================================================================

# DATABASE_URL=postgres://user:password@localhost:5432/transporti_v1

# =============================================================================
# CORS
# =============================================================================

# Comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# EXTERNAL SERVICES (future)
# =============================================================================

# Payment Gateway
# PAYMENT_GATEWAY_API_KEY=

# SMS Provider (for phone verification)
# SMS_API_KEY=
