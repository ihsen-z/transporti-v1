# Copier en .env (jamais commité). Les variables EXPO_PUBLIC_* sont exposées
# au bundle client — n'y mettre AUCUN secret, uniquement des valeurs publiques.

# Base URL de l'API backend (préfixe /api/v1 ajouté par le client).
# Dev émulateur Android : http://10.0.2.2:8000  |  iOS simulateur : http://localhost:8000
# Staging Render : https://<votre-service>.onrender.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Timeout des requêtes HTTP (ms)
EXPO_PUBLIC_API_TIMEOUT=15000
